#include <stdio.h>

int main() {
    int n, i;
    
        printf("Enter number of elements: ");
            scanf("%d", &n);
            
                int arr[n];
                    int *ptr = arr;
                    
                        printf("Enter array elements:\n");
                            for(i = 0; i < n; i++)
                                    scanf("%d", ptr + i);
                                    
                                        int largest = *ptr;
                                        
                                            for(i = 1; i < n; i++) {
                                                    if(*(ptr + i) > largest)
                                                                largest = *(ptr + i);
                                                                    }
                                                                    
                                                                        printf("Largest element = %d", largest);
                                                                        
                                                                            return 0;
                                                                            }                                              }                                             }