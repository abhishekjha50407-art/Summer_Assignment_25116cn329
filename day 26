                                                                                                                        high = mid - 1;
                                                                                                                                } else {
                                                                                                                                            low = mid + 1;
                                                                                                                                                    }
                                                                                                                                                        }

                                                                                                                                                            if (!found)
                                                                                                                                                                    printf("Element not found.\n");

