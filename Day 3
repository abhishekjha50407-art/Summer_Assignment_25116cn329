#include <stdio.h>

int main() {
    int n1, n2, a, b, temp, gcd, lcm;

        printf("Enter two integers: ");
            scanf("%d %d", &n1, &n2);

                a = n1;
                    b = n2;

                        // First find GCD using Euclidean algorithm
                            while (b != 0) {
                                    temp = b;
                                            b = a % b;
                                                    a = temp;
                                                        }
                                                            gcd = a;

                                                                // LCM formula: (n1 * n2) / GCD
                                                                    lcm = (n1 * n2) / gcd;

                                                                        printf("LCM of %d and %d is %d\n", n1, n2, lcm);

                                                                            return 0;
