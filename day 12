        printf("Enter number of elements: ");
            scanf("%d", &n);
            
                int arr[n];
                
                    printf("Enter elements:\n");
                        for(i = 0; i < n; i++)
                                scanf("%d", &arr[i]);
                                
                                    for(i = 0; i < n; i++) {
