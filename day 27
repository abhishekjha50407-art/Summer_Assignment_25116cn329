#include <stdio.h>

int partition(int arr[], int low, int high) {
    int pivot = arr[high];
        int i = low - 1, temp, j;
        
            for (j = low; j < high; j++) {
                    if (arr[j] < pivot) {
                                i++;
                                            temp = arr[i];
                                                        arr[i] = arr[j];
                                                                    arr[j] = temp;
                                                                            }
                                                                                }
                                                                                
                                                                                    temp = arr[i + 1];
                                                                                        arr[i + 1] = arr[high];
                                                                                            arr[high] = temp;
                                                                                            
                                                                                                return i + 1;
                                                                                                }
                                                                                                
                                                                                                void quickSort(int arr[], int low, int high) {
                                                                                                    if (low < high) {
                                                                                                            int pi = partition(arr, low, high);
                                                                                                            
                                                                                                                    quickSort(arr, low, pi - 1);
                                                                                                                            quickSort(arr, pi + 1, high);
                                                                                                                                }
                                                                                                                                }
                                                                                                                                
