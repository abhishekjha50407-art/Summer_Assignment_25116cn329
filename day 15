#include <stdio.h>

int main() {
    int n, i, j = 0;
    
        printf("Enter number of elements: ");
            scanf("%d", &n);
            
                int arr[n], temp[n];
                
                    printf("Enter array elements:\n");
                        for(i = 0; i < n; i++)
                                scanf("%d", &arr[i]);
                                
                                    // Store non-zero elements
                                        for(i = 0; i < n; i++) {
                                                if(arr[i] != 0)
                                                            temp[j++] = arr[i];
                                                                }
                                                                
                                                                    // Fill remaining positions with zeros
                                                                        while(j < n)
                                                                                temp[j++] = 0;
                                                                                
                                                                                    printf("Array after moving zeros to end:\n");
                                                                                        for(i = 0; i < n; i++)
                                                                                                printf("%d ", temp[i]);
                                                                                                
                                                                                                    return 0;
                                                                                                    }                                                                    }                                                               }